	},

	"CloudflareR2": {
		"AccountId": "",
		"AccessKeyId": "",
		"SecretAccessKey": "",
		"BucketName": "",
		"PublicBaseUrl": "",
		"MaxFileSizeBytes": 52428800,
		"DownloadTimeoutSeconds": 30
	}
}
