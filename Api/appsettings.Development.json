{
	"Logging": {
		"LogLevel": {
			"Default": "Information",
			"Microsoft.AspNetCore": "Warning"
		}
	},

	"ConnectionStrings": {
		"NewsParserDbContext": ""
	},

	"Jwt": {
		"SecretKey": "",
		"Issuer": "https://localhost:7054",
		"Audience": "https://localhost:7054",
		"ExpirationHours": 24
	},

	"Ai": {
