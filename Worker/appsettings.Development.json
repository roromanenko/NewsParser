{
	"Logging": {
		"LogLevel": {
			"Default": "Information",
			"Worker.Workers.SourceFetcherWorker": "Debug",
			"Infrastructure.AI": "Debug",
			"Infrastructure.Parsers": "Debug"
		}
	},

	"ConnectionStrings": {
		"NewsParserDbContext": ""
	},

	"RssFetcher": {
		"IntervalSeconds": 60
	},

	"Ai": {
		"Normalization": {
			"TargetLanguage": "uk",
			"TargetLanguageName": "Ukrainian"
		},
		"Gemini": {
			"ApiKey": "",
			"AnalyzerModel": "gemini-2.5-flash",
			"EmbeddingModel": "gemini-embedding-2-preview",
			"DeduplicationThreshold": 0.85,
			"DeduplicationWindowHours": 24
		},
		"Anthropic": {
			"ApiKey": "",
			"AnalyzerModel": "claude-haiku-4-5-20251001",
			"GeneratorModel": "claude-sonnet-4-5",
			"ContentGeneratorModel": "claude-sonnet-4-5",
			"ClassifierModel": "claude-haiku-4-5-20251001",
			"ContradictionDetectorModel": "claude-haiku-4-5-20251001",
			"SummaryUpdaterModel": "claude-haiku-4-5-20251001",
			"KeyFactsExtractorModel": "claude-haiku-4-5-20251001",
			"TitleGeneratorModel": "claude-haiku-4-5-20251001"
		}
	},

	"EventImportance": {
		"Weights": {
			"Volume": 0.20,
			"Sources": 0.30,
			"Velocity": 0.20,
			"Ai": 0.30
		},
		"Caps": {
			"Volume": 20,
			"Sources": 5,
			"Velocity": 5
		},
		"HalfLifeHours": 12,
		"Tiers": {
			"BreakingThreshold": 75,
			"HighThreshold": 50,
			"NormalThreshold": 25
		}
	},

	"ArticleProcessing": {
		"AnalyzerIntervalSeconds": 60,
		"GeneratorIntervalSeconds": 60,
		"PublicationGenerationIntervalSeconds": 60,
		"PublicationWorkerIntervalSeconds": 30,
		"BatchSize": 10,
		"MaxRetryCount": 5,
		"IntervalSeconds": 60,
		"SimilarityWindowHours": 24,
		"AutoSameEventThreshold": 0.80,
		"AutoNewEventThreshold": 0.70,
		"MinUpdateIntervalMinutes": 30,
		"MaxUpdatesPerDay": 10,
		"MaxSimilarEvents": 10,
		"CountUpdatesFromHours": 24
	},

	"PublishingWorker": {
		"IntervalSeconds": 30,
		"BatchSize": 10
	},

	"Validation": {
		"MinContentLength": 100,
		"MinTitleLength": 10,
		"MaxAgeHours": 72,
		"TitleSimilarityThreshold": 85,
		"TitleDeduplicationWindowHours": 24,
		"ExcludedKeywords": [ "advertisement", "sponsored", "promoted", "реклама", "спонсор" ]
	},

	"Telegram": {
		"BotToken": "",
		"ApiId": 0,
		"ApiHash": "",
		"PhoneNumber": "",
		"SessionFilePath": "telegram.session"
	},

	"ArticleScraper": {
		"Enabled": true,
		"RequestTimeoutSeconds": 15,
		"MaxHtmlSizeBytes": 2097152,
		"MaxConcurrencyPerFeed": 4,
		"UserAgent": "NewsParserBot/1.0",
		"MaxTagsPerArticle": 20
	},

	"CloudflareR2": {
		"AccountId": "",
		"AccessKeyId": "",
		"SecretAccessKey": "",
		"BucketName": "",
		"PublicBaseUrl": "",
		"MaxFileSizeBytes": 52428800,
		"DownloadTimeoutSeconds": 90,
		//additional settings for Cloudflare R2 token generation (if needed)
		"TokenValue": "",
		"JurisdictionSpecificEndpoint": ""
	}
}
